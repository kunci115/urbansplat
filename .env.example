# Copy to .env before `docker-compose up`.

# Set to 0 on a CUDA host with COLMAP + gsplat installed for real reconstruction.
URBANSPLAT_DRY_RUN=1
URBANSPLAT_WORK_DIR=/tmp/urbansplat

# Service wiring (matches docker-compose service names).
URBANSPLAT_DATABASE_URL=postgresql+psycopg://urbansplat:urbansplat@postgres:5432/urbansplat
URBANSPLAT_REDIS_URL=redis://redis:6379/0

URBANSPLAT_S3_ENDPOINT=minio:9000
URBANSPLAT_S3_ACCESS_KEY=urbansplat
URBANSPLAT_S3_SECRET_KEY=urbansplat
URBANSPLAT_S3_SECURE=false
URBANSPLAT_S3_BUCKET=urbansplat

# Pipeline tuning.
URBANSPLAT_FRAME_SAMPLE_FPS=2.0
URBANSPLAT_BLUR_THRESHOLD=60.0
URBANSPLAT_TRAIN_ITERATIONS=30000
URBANSPLAT_CUBEMAP_FACE_SIZE=1024
